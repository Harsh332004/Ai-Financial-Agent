# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/financial_agent

# Groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# JWT Auth
SECRET_KEY=your_jwt_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# News API (free from newsapi.org)
NEWS_API_KEY=your_news_api_key_here

# File paths
UPLOAD_DIR=uploads
INDEX_DIR=indexes
REPORTS_DIR=reports

# Models
EMBED_MODEL=all-MiniLM-L6-v2
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# RAG settings
CHUNK_SIZE=300
CHUNK_OVERLAP=50
TOP_K_INITIAL=10
TOP_K_FINAL=3
MAX_HISTORY=6

# Evaluation (evaluate.py – RAGAS evaluation suite)
# Uses the same GROQ_API_KEY and GROQ_MODEL already defined above.
# No additional API keys required.
